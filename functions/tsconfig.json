{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "outDir": "lib",
    "sourceMap": true,
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "server-only": ["./src/lib/server-only-mock.ts"],
      "@ai-sdk/devtools": ["./src/lib/ai-sdk-devtools-mock.ts"],
      "@/data/*": ["../packages/data/src/*"],
      "@/workflow/*": ["../packages/workflow/src/*"],
      "@/lib/*": ["./src/lib/*", "../src/lib/*"],
      "@/ui/*": ["../src/ui/*"],
      "@/*": ["./src/*", "../src/*"]
    }
  },
  "compileOnSave": true,
  "include": ["src", "../packages/data/src", "../packages/workflow/src"]
}
