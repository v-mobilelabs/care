{
  "rules": {
    "presence": {
      ".indexOn": ["kind"],
      "$uid": {
        // Any authenticated user can read any presence node.
        // This lets patients see if a doctor is online, and vice versa.
        ".read": "auth != null",

        // Only the user themselves can write their own presence node.
        // The Admin SDK (used in Cloud Functions) bypasses these rules.
        ".write": "auth != null && auth.uid === $uid",

        ".validate": "newData.hasChildren(['online', 'lastSeen', 'kind'])",

        "online": { ".validate": "newData.isBoolean()" },
        "lastSeen": { ".validate": "newData.isNumber()" },
        "kind": {
          ".validate": "newData.isString() && (newData.val() === 'user' || newData.val() === 'doctor')"
        },

        // Reject any extra fields.
        "$other": { ".validate": false }
      }
    },

    // ── On-demand video call signaling ────────────────────────────────────────
    // Incoming call queue — only the target doctor can read their queue.
    // Writes are performed exclusively by the Admin SDK (server-side API routes).
    "call-requests": {
      "$doctorId": {
        ".read": "auth != null && auth.uid === $doctorId",
        ".write": false
      }
    },

    // Public queue size counter — any authenticated user can read, only Admin SDK writes.
    // Allows patients to see how many people are waiting for a given doctor.
    "queue-size": {
      "$doctorId": {
        ".read": "auth != null",
        ".write": false,
        ".validate": "newData.isNumber()"
      }
    },

    // Patient call state — only the patient themselves can read their state.
    // Writes are performed exclusively by the Admin SDK (server-side API routes).
    "call-state": {
      "$patientId": {
        ".read": "auth != null && auth.uid === $patientId",
        ".write": false
      }
    },

    // In-call consent invite signaling.
    // The patient can read their own pending invite and write back acceptance.
    // Server writes via Admin SDK (bypasses these rules).
    "in-call-consent": {
      "$patientId": {
        "$requestId": {
          ".read": "auth != null && auth.uid === $patientId",
          ".write": "auth != null && auth.uid === $patientId"
        }
      }
    },

    // Doctor acknowledgement node: patient writes here after accepting, doctor reads it.
    "in-call-consent-ack": {
      "$doctorId": {
        "$requestId": {
          // Doctor reads their own acks.
          ".read": "auth != null && auth.uid === $doctorId",
          // Any authenticated user can write (patient writes acceptance here).
          ".write": "auth != null"
        }
      }
    },

    // Deny all reads/writes to any other path.
    "$other": { ".read": false, ".write": false }
  }
}
